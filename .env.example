# Google AI Studio API key.
# - Used by scripts/generate-images.ts to pre-generate training photos (build-time).
# - Used by /api/judge route at runtime to evaluate free-text answers (Gemini 2.5 Flash).
GOOGLE_GENAI_API_KEY=

# Supabase — cloud progress sync. Optional: if absent, app runs in
# localStorage-only mode (no auth UI, no /account, no cross-device sync).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
